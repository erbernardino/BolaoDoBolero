rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function prazoAberto() {
      return isAuthenticated() &&
        request.time < get(/databases/$(database)/documents/config/geral).data.prazoLimitePalpites;
    }

    function isLiberado() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.liberado == true;
    }

    function isValidScore(value) {
      return value is int && value >= 0 && value <= 99;
    }

    function canReadPalpite(uid, jogoId) {
      return isOwner(uid) || isAdmin()
        || get(/databases/$(database)/documents/config/geral).data.visibilidadePalpites == 'sempre'
        || (
          get(/databases/$(database)/documents/config/geral).data.visibilidadePalpites == 'apos_prazo'
          && request.time >= get(/databases/$(database)/documents/config/geral).data.prazoLimitePalpites
        )
        || (
          get(/databases/$(database)/documents/config/geral).data.visibilidadePalpites == 'apos_jogo'
          && get(/databases/$(database)/documents/jogos/$(jogoId)).data.encerrado == true
        );
    }

    function canReadPalpiteEspecial(uid) {
      return isOwner(uid) || isAdmin()
        || get(/databases/$(database)/documents/config/geral).data.visibilidadePalpites == 'sempre'
        || (
          get(/databases/$(database)/documents/config/geral).data.visibilidadePalpites == 'apos_prazo'
          && request.time >= get(/databases/$(database)/documents/config/geral).data.prazoLimitePalpites
        );
    }

    function isValidPalpite(data) {
      return data.keys().hasOnly([
          'id', 'uid', 'jogoId', 'timeCasa', 'timeVisitante',
          'golsCasa', 'golsVisitante', 'classificado', 'criadoEm'
        ])
        && data.uid is string
        && data.jogoId is string
        && data.timeCasa is string
        && data.timeVisitante is string
        && isValidScore(data.golsCasa)
        && isValidScore(data.golsVisitante)
        && (data.classificado == null || data.classificado is string)
        && data.criadoEm is timestamp;
    }

    function isValidPalpiteEspecial(data, uid) {
      return data.keys().hasOnly([
          'uid', 'campeao', 'vice', 'terceiro', 'quarto', 'paisArtilheiro', 'criadoEm'
        ])
        && data.uid == uid
        && data.campeao is string
        && data.vice is string
        && data.terceiro is string
        && data.quarto is string
        && data.paisArtilheiro is string
        && data.criadoEm is timestamp;
    }

    function isValidDesempateTerceiros(data, uid) {
      return data.keys().hasOnly(['uid', 'pontosDisciplinares', 'criadoEm'])
        && data.uid == uid
        && data.pontosDisciplinares is map
        && data.criadoEm is timestamp;
    }

    function isValidUsuarioCreate(data) {
      return data.keys().hasOnly([
          'uid', 'nome', 'apelido', 'email', 'telefone', 'role',
          'liberado', 'conviteId', 'criadoEm', 'fcmToken'
        ])
        && data.role == 'participante'
        && data.liberado == false
        && (!('uid' in data) || data.uid == request.auth.uid);
    }

    function isValidUsuarioOwnerUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['nome', 'apelido', 'email', 'telefone', 'fcmToken'])
        && request.resource.data.role == resource.data.role
        && request.resource.data.liberado == resource.data.liberado
        && request.resource.data.get('uid', request.auth.uid) == resource.data.get('uid', request.auth.uid)
        && request.resource.data.conviteId == resource.data.conviteId;
    }

    // /config/{docId}: read by authenticated, write by admin
    // Inclui config/geral e config/resultado_especial
    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // /times/{timeId}: read by authenticated, write by admin
    match /times/{timeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // /grupos/{grupoId}: read by authenticated, write by admin
    match /grupos/{grupoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // /jogos/{jogoId}: read by authenticated, write by admin
    match /jogos/{jogoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // /palpites/{palpiteId}: leitura segue config de visibilidade; escrita só pelo dono liberado antes do prazo
    match /palpites/{palpiteId} {
      allow read: if isAuthenticated() && canReadPalpite(resource.data.uid, resource.data.jogoId);
      allow create: if isOwner(request.resource.data.uid)
        && prazoAberto()
        && isLiberado()
        && isValidPalpite(request.resource.data);
      allow update: if isOwner(resource.data.uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.jogoId == resource.data.jogoId
        && prazoAberto()
        && isLiberado()
        && isValidPalpite(request.resource.data);
      allow delete: if false;
    }

    // /palpites_especiais/{uid}: leitura segue config de visibilidade geral; escrita só pelo dono antes do prazo
    match /palpites_especiais/{uid} {
      allow read: if isAuthenticated() && canReadPalpiteEspecial(uid);
      allow create: if isOwner(uid)
        && prazoAberto()
        && isLiberado()
        && isValidPalpiteEspecial(request.resource.data, uid);
      allow update: if isOwner(uid)
        && request.resource.data.uid == resource.data.uid
        && prazoAberto()
        && isLiberado()
        && isValidPalpiteEspecial(request.resource.data, uid);
      allow delete: if false;
    }

    // /desempates_terceiros/{uid}: pontos disciplinares usados só para posicionar 3os colocados no chaveamento
    match /desempates_terceiros/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid)
        && prazoAberto()
        && isLiberado()
        && isValidDesempateTerceiros(request.resource.data, uid);
      allow update: if isOwner(uid)
        && prazoAberto()
        && isLiberado()
        && request.resource.data.uid == resource.data.uid
        && isValidDesempateTerceiros(request.resource.data, uid);
      allow delete: if false;
    }

    // /chat/{messageId}: global chat
    match /chat/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isOwner(resource.data.uid) || isAdmin();
      allow update: if false;
    }

    // /notificacoes_usuario/{uid}/items — cliente só lê/atualiza as próprias; criações usam Admin SDK/Functions
    match /notificacoes_usuario/{uid}/items/{notifId} {
      allow read: if isOwner(uid);
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lida'])
        && request.resource.data.lida is bool;
      allow create: if isAdmin();
      allow delete: if false;
    }

    // /ranking/{uid}: read by authenticated, write only by Cloud Functions via Admin SDK
    match /ranking/{uid} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // /usuarios/{uid}: read by any authenticated user, create/update by owner, admin can update any
    // Usuário não pode alterar o próprio role (prevenção de escalação de privilégio)
    match /usuarios/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUsuarioCreate(request.resource.data);
      allow update: if isAdmin()
        || (isOwner(uid) && isValidUsuarioOwnerUpdate());
      allow delete: if false;
    }

    // /usuarios_excluidos/{uid}: backup de usuários excluídos, escrita só via Admin SDK
    match /usuarios_excluidos/{uid} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // /convites/{conviteId}: read by anyone, create by admin, update restrito
    // Convite unico: transição usado=false→true com campos controlados
    // Convite multiplo: não precisa ser marcado como usado (admin pode atualizar)
    match /convites/{conviteId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || (
        isAuthenticated()
        && resource.data.tipo != 'multiplo'
        && !resource.data.usado
        && request.resource.data.usado == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usado', 'usadoPor'])
      );
      allow delete: if false;
    }
  }
}
